GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
SAMBANOVA_API_KEY=
MISTRAL_API_KEY=

# ----- Optional multi-tenant authentication (disabled by default) -----
# Set AUTH_ENABLED=true to require login; each user gets a private workspace.
AUTH_ENABLED=false
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=168

# ----- Screen-capture contextual memory (privacy-sensitive) -----
# Set to false to stop the app from screenshotting + OCR-ing your screen.
# Recommended false for new users / public GitHub clones (faster, more private).
SCREEN_CAPTURE_ENABLED=false

# ----- Optional background task queue (needs a running Redis) -----
CELERY_ENABLED=false
REDIS_URL=redis://localhost:6379/0
